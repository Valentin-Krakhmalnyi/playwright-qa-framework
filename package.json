{
  "name": "playwright-qa-framework",
  "version": "2.5.0",
  "description": "Professional end-to-end and API test automation framework built with Playwright and TypeScript. Actively maintained since early 2020.",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:api": "playwright test tests/api",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write '**/*.{ts,js,json,md}'"
  },
  "keywords": [
    "playwright",
    "typescript",
    "e2e-testing",
    "api-testing",
    "automation",
    "qa-framework"
  ],
  "author": "Valentin Krakhmalnyi",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.13.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.19.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}